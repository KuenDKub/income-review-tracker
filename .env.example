# Database - PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/income_review_tracker

# Supabase Storage (optional - for file uploads on Vercel)
# Create a public bucket in Supabase Dashboard first
SUPABASE_S3_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key
SUPABASE_PUBLIC_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public
SUPABASE_STORAGE_BUCKET=income-review-tracker

# OpenRouter (for AI Storyline)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-haiku
# Vision-capable model used for brief-image OCR. Must accept image input.
# Free options (availability rotates — see openrouter.ai/models, "Vision" filter):
#   google/gemma-4-26b-a4b-it:free  |  google/gemma-4-31b-it:free
OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free

# App login (single user)
APP_AUTH_EMAIL=you@example.com
APP_AUTH_PASSWORD=change-me
# HMAC secret for the session cookie. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=generate-a-random-secret

# Apple/Google Calendar subscription feed (one-way). Secret token placed in the
# feed URL (?token=...) that authorizes the public /api/calendar/feed.ics
# endpoint. Leave unset to hide/disable the feed.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CALENDAR_FEED_TOKEN=generate-a-random-secret
